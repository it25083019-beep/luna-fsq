GOOGLE_API_KEY=
MODEL_NAME=gemini-2.5-flash
ADMIN_USER_IDS=admin_root
ENV=dev

# Local default
DATABASE_URL=sqlite:///./data/luna.db

# Render Postgres (Internal Database URL from dashboard):
# DATABASE_URL=postgresql://luna:PASSWORD@HOST/luna_fsq

# MySQL Workbench:
# DATABASE_URL=mysql+pymysql://luna:PASSWORD@127.0.0.1:3306/luna_fsq

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=10080
ADMIN_EMAIL=admin@luna.local
ADMIN_PASSWORD=admin123456
# Set ADMIN_SYNC_PASSWORD=true to reset admin password from env on every startup
ADMIN_SYNC_PASSWORD=false
APP_BASE_URL=http://127.0.0.1:8006

# Optional SMTP for password reset emails (production)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_TLS=true
# PASSWORD_RESET_EXPIRE_MINUTES=60

ALLOWED_ORIGINS=*
